rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }
    // Un coach est coach global (role=="coach") OU coach d'une équipe donnée
    function isCoachOf(teamId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "coach" ||
        exists(/databases/$(database)/documents/teams/$(teamId)/coaches/$(request.auth.uid))
      );
    }

    // Données privées utilisateur (athlète)
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid; // lui-même
      allow read: if isAdmin(); // admin peut lire
    }

    // Liste des admins (tu peux gérer ça à la main)
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false; // géré via console/CLI
    }

    // Équipes & sous-collections
    match /teams/{teamId} {
      allow read: if isAdmin() || isCoachOf(teamId);
      allow create, update, delete: if isAdmin();
    }
    match /teams/{teamId}/{sub=**} {
      allow read: if isAdmin() || isCoachOf(teamId);
      // écriture (membres/coachs/paramètres) réservée à l'admin
      allow write: if isAdmin();
    }

    // Réponses miroir d'équipe (écrites par Cloud Functions via Admin SDK => bypass)
    match /teams/{teamId}/responses/{docId} {
      allow read: if isAdmin() || isCoachOf(teamId);
      allow write: if isAdmin(); // pour éventuels correctifs manuels par admin
    }

    // Agrégats journaliers
    match /teams/{teamId}/daily/{dateId} {
      allow read: if isAdmin() || isCoachOf(teamId);
      allow write: if isAdmin();
    }
  }
}